# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts


# Seed PDFs dropped by `pnpm configure` or uploaded via the admin console.
/documents/

# Workspace package build outputs
/dist/
/packages/*/dist/

/packages/*/node_modules/

# Agent runtime files (not part of the app code)
.agents/skills/
.fallow/
.fallowrc.json
.neon
skills-lock.json

# Proposed plans (never commit)
proposedplans.md
OUTSTANDING_ISSUES.md
