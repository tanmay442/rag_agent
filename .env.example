# Copy to .env.local and fill in real values.
# This file is committed so contributors know which variables to set.

# 1. Database (Neon Serverless Postgres)
DATABASE_URL=

# 2. Google AI Studio (free 768-dim embeddings)
AI_STUDIO_KEY=
#    Embedding vector dimension. Must match the pgvector column size.
#    Default 768 (gemini-embedding-001 / nomic-embed-text). Change only
#    if using a different embedding model — requires a DB migration.
EMBEDDING_DIMENSION=768

# 3. LLM provider switches
#    EMBEDDING_PROVIDER: google | openai | ollama. Default: google.
#    CHAT_PROVIDER: openai | google | ollama. Default: openai.
EMBEDDING_PROVIDER=google
CHAT_PROVIDER=openai

# 3a. Google provider (used when provider = google, or for google chat)
#    No extra vars; uses AI_STUDIO_KEY above.

# 3b. OpenAI-compatible embedding endpoint (used when EMBEDDING_PROVIDER=openai)
#    Falls back to CUSTOM_LLM_API_KEY / CUSTOM_LLM_BASE_URL below.
OPENAI_EMBEDDING_API_KEY=
OPENAI_EMBEDDING_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#    text-embedding-3-small defaults to 1536-dim. The adapter pins
#    dimensions to EMBEDDING_DIMENSION (default 768) so the output
#    matches the pgvector column. Use a model/supporting endpoint.

# 3c. Ollama (zero-key local testing)
#    Ollama exposes an OpenAI-compatible /v1 endpoint.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1

# 3d. Custom OpenAI-compatible chat endpoint (used when CHAT_PROVIDER=openai)
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
LLM_MODEL=custom-chat-model

# 4. Clerk auth (Vercel Marketplace: vercel integration add clerk)
#    The marketplace integration auto-provisions these two.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
#    Sign-in / sign-up routes the user lands on after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# 5. Neon project management (optional, for CI test branch creation)
NEON_API_KEY=
NEON_PROJECT_ID=

# 6. Seed script config (optional, used by `pnpm seed`)
SEED_DOCS_DIR=./documents
SEED_USER_ID=seed-script

# 7. Admin bootstrap (optional if you ran `pnpm configure`).
#    Comma-separated list of emails; the first time a user with
#    one of these emails signs in, they're given the `admin` role
#    automatically. `pnpm configure` writes this for you from
#    config/app.config.ts → adminEmails. After that, admins
#    promote others from /admin/users.
ADMIN_EMAILS=

# 8. Logging (optional)
#    One of: error, warn, info, debug. Default: info.
LOG_LEVEL=info
