# Copy to .env.local and fill in real values.
# This file is committed so contributors know which variables to set.

# 1. Database (Neon Serverless Postgres)
DATABASE_URL=

# 2. Google AI Studio (free 768-dim embeddings)
AI_STUDIO_KEY=

# 3. Custom OpenAI-compatible chat endpoint
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_BASE_URL=
LLM_MODEL=custom-chat-model

# 4. Clerk auth (Vercel Marketplace: vercel integration add clerk)
#    The marketplace integration auto-provisions these two.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
#    Sign-in / sign-up routes the user lands on after auth.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# 5. Admin bootstrap. Comma-separated list of emails; the first time a
#    user with one of these emails signs in, they're given the
#    `admin` role automatically. After that, admins promote others
#    from /admin/users.
ADMIN_EMAILS=
