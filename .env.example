# Copy to .env.local and fill in real values.
# Defaults below boot against `docker compose up -d db` with zero
# external API keys (using Ollama for LLM).

# 1. Database
#    Uses local Docker Postgres. For Vercel, use your Neon URL.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ragagent

# 2. Embedding provider: google | openai | ollama (default: google)
#    For zero-key local dev, use ollama:
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
#    For production (Google):
# EMBEDDING_PROVIDER=google
# AI_STUDIO_KEY=
#    For OpenAI-compatible:
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_API_KEY=
# OPENAI_EMBEDDING_BASE_URL=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

EMBEDDING_DIMENSION=768

# 3. Chat provider: openai | google | ollama (default: openai)
#    For zero-key local dev, use ollama:
CHAT_PROVIDER=ollama
OLLAMA_CHAT_MODEL=gemma2:2b
#    For production (OpenAI-compatible):
# CHAT_PROVIDER=openai
# CUSTOM_LLM_API_KEY=
# CUSTOM_LLM_BASE_URL=
# LLM_MODEL=custom-chat-model

# 4. Blob storage: filesystem | r2 | s3 (default: filesystem)
BLOB_STORAGE_PROVIDER=filesystem
BLOB_FS_DIR=./.blobs
#    For production (Cloudflare R2):
# BLOB_STORAGE_PROVIDER=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# 5. Auth: clerk (only supported provider currently)
AUTH_PROVIDER=clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# 6. Rate limiting + query stats (optional, for multi-instance)
#    Without these, in-memory adapters are used (fine for local dev).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# 7. Async ingest queue (optional, for large PDFs)
#    Without these, all uploads are synchronous.
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# QSTASH_INGEST_WORKER_URL=

# 8. Neon project management (optional, for CI test branches)
# NEON_API_KEY=
# NEON_PROJECT_ID=

# 9. Seed script config (optional)
SEED_DOCS_DIR=./documents
SEED_USER_ID=seed-script

# 10. Admin bootstrap (optional)
#     Comma-separated list of emails.
ADMIN_EMAILS=

# 11. Logging (optional)
#     One of: error, warn, info, debug. Default: info.
LOG_LEVEL=info

# 12. Reranking (second-stage, Session 6) — 3-way feature flag
#     RERANKER_PROVIDER selects ONE of three modes. This is the single toggle
#     a person flips to choose which reranker runs (default = cosine).
#
#       cosine  -> the original pre-Session-6 bi-encoder ordering. NO reranker
#                  is loaded (zero native deps). The safe SERVERLESS default.
#       local   -> on-device Xenova cross-encoder, NO API key (needs native
#                  onnxruntime ~137 MB + a runtime model download).
#       cohere  -> hosted Cohere Rerank API (needs COHERE_API_KEY).
#
#     AUTO-FALLBACK: in every mode, if the chosen reranker FAILS to load or
#     call (Xenova on a read-only/over-limit serverless FS, Cohere with a
#     missing key or API error), searchChunks AUTOMATICALLY falls back to
#     cosine ordering. No crash.
#
#     Default (recommended for Vercel serverless): cosine.
RERANKER_PROVIDER=cosine
# CANDIDATE_POOL=30          # broad pool retrieved before reranking (local/cohere)
# RERANK_TOP_N=3             # final chunks returned to the LLM
#
#     --- Opt-in: on-device Xenova cross-encoder (local dev / Docker) ---
# RERANKER_PROVIDER=local
# LOCAL_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
#     On a read-only FS (Docker/serverless root) point the model cache at a
#     writable dir so the HuggingFace download does not fail:
# TRANSFORMERS_CACHE=/tmp/xenova-cache
#     On Vercel serverless `local` may exceed the function size limit or fail
#     on the read-only FS; if so it falls back to cosine automatically.
#
#     --- Opt-in: hosted Cohere Rerank API (serverless-native, no native deps) ---
# RERANKER_PROVIDER=cohere
# COHERE_API_KEY=
# COHERE_RERANK_MODEL=rerank-english-v3.0

# 13. Agentic retrieval loop + guardrails (Session 8)
#     When on, chat retrieval runs: rewrite query -> hybrid/rerank retrieve ->
#     grade+drop irrelevant chunks -> retry once if weak -> generate ->
#     hallucination check. Out-of-domain refuses and offers createSupportTicket.
AGENTIC_ENABLED=true
# GRADE_MODEL=                 # optional cheap model id for the rewrite/grade/hallucination calls
# OUT_OF_DOMAIN_THRESHOLD=0.3  # max-similarity below this with zero kept chunks -> refuse
# AGENT_STEP_BUDGET=8          # stepCountIs budget for the agentic loop
# AGENTIC_RETRIEVE_LIMIT=10    # candidate pool for the loop's re-retrieval
# AGENTIC_MAX_RETRIES=1        # rewrite+retry passes before falling back to a ticket

# 14. Answer cache + observability + eval (Session 10)
#     When on, first-turn query-keyed answers are cached in the SAME Upstash
#     Redis used for rate-limiting + query stats (no second connection).
#     Follow-up turns with conversation state are never cached.
ANSWER_CACHE_ENABLED=true
# ANSWER_CACHE_TTL_SEC=3600    # cache TTL (seconds)
# TRACE_ENABLED=true            # emit rag.* tracing spans via the logger
# EVAL_FAITHFULNESS_THRESHOLD=0.7  # pnpm eval CI gate (mean faithfulness)

